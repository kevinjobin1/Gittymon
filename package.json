{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && cp -r dist/client/* dist/ && rm -rf dist/client && mv dist/index.html dist/shell.html && node scripts/inline-shell.cjs && node scripts/patch-wrangler-config.cjs",
    "deploy": "npm run build && npx wrangler deploy --assets dist",
    "deploy:staging": "npm run build && npx wrangler deploy --assets dist --env staging",
    "deploy:prod": "npm run build && npx wrangler deploy --assets dist",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "preview": "npm run build && wrangler dev",
    "worker:dev": "npx wrangler dev"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gifenc": "^1.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.39.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-github-btn": "^1.4.0",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.38.0",
    "@cloudflare/workers-types": "^4.20260525.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  }
}

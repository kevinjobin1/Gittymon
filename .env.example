[TEMPLATE]
# GROQ_API_KEY: Required for Groq (Llama 3) AI API calls.
# Get a free API key at https://console.groq.com
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CLOUDFLARE_API_TOKEN: Required for Cloudflare API calls.
# Get a free API token at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN="YOUR_CLOUDFLARE_API_TOKEN"

# REVALIDATE_KEY: Optional shared secret for the /api/revalidate-sitemap endpoint.
# If set, requests must include an X-Revalidate-Key header matching this value.
# Leave unset in local dev to allow unprotected access.
REVALIDATE_KEY=""
